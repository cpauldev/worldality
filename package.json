{
  "name": "worldality",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "examples/*"
  ],
  "devDependencies": {
    "bun-types": "^1.3.14"
  },
  "scripts": {
    "build": "bun run --filter './examples/*' build",
    "examples": "bun scripts/run.ts",
    "dev:astro": "bun --cwd examples/astro dev",
    "dev:nextjs": "bun --cwd examples/nextjs dev",
    "dev:nuxt": "bun --cwd examples/nuxt dev",
    "dev:react": "bun --cwd examples/react dev",
    "dev:react-router": "bun --cwd examples/react-router dev",
    "dev:solid": "bun --cwd examples/solid dev",
    "dev:sveltekit": "bun --cwd examples/sveltekit dev",
    "dev:vanilla": "bun --cwd examples/vanilla dev",
    "dev:vue": "bun --cwd examples/vue dev"
  }
}
