{
  "scan": "src",
  "output": "public/worldality",
  "manifest": "public",
  "locales": {
    "en": {
      "name": "English",
      "nativeName": "English",
      "dir": "ltr"
    },
    "ar": {
      "name": "Arabic",
      "nativeName": "العربية",
      "dir": "rtl"
    },
    "ko": {
      "name": "Korean",
      "nativeName": "한국어",
      "dir": "ltr"
    }
  },
  "defaultLocale": "en",
  "extensions": [".ts", ".js", ".vue"],
  "exclude": [
    "node_modules",
    ".git",
    "dist",
    "build",
    "out",
    ".next",
    ".turbo",
    ".cache",
    ".vercel",
    ".netlify",
    "coverage",
    "__tests__",
    "test",
    "tests"
  ],
  "content": {
    "pages": []
  },
  "pagePatterns": ["src/pages/**/*.vue"],
  "routing": true,
  "framework": "vue"
}
