{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "rootDirs": [".", "./.react-router/types"],
    "types": ["vite/client", "node"]
  },
  "include": ["app", ".react-router/types/**/*"]
}
