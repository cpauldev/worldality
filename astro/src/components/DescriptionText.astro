---
import { splitMonospaceTokens } from "../lib/description";

interface Props {
  className?: string;
  text: string;
}

const { className = "", text } = Astro.props;
const parts = splitMonospaceTokens(text);
---

<p class={className}>
  {
    parts.map((part) =>
      part.mono ? <span class="font-mono">{part.text}</span> : part.text,
    )
  }
</p>
