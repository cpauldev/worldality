---
import { codeTextVariants, cn, inputVariants, labelVariants } from "example-shared/ui";
import { BASIC_MESSAGES } from "example-shared/constants";

import type { AstroExampleState } from "../lib/page-state";
import { ASTRO_FRAMEWORK, ASTRO_IDS } from "../lib/page-state";
import type { AstroServerHelpers } from "../lib/server-helpers";
import ExampleBadge from "./ExampleBadge.astro";
import ExampleCard from "./ExampleCard.astro";
import ExampleSection from "./ExampleSection.astro";

interface Props {
  helpers: AstroServerHelpers;
  pageTitle: string;
  state: AstroExampleState;
}

const { helpers, pageTitle, state } = Astro.props;
const controlLabelClass = cn(labelVariants());
const controlInputClass = cn(inputVariants(), "body-sm");
const codeTextClass = cn(codeTextVariants(), "body-sm");
const richUnsupported = helpers.translateText("Not supported in {framework}", {
  framework: ASTRO_FRAMEWORK.label,
});
const richTextSnippet = [
  "// Not available in worldality",
  `// Use t.markup('${BASIC_MESSAGES.interpolation}', { name: '<em>Alice</em>' })`,
].join("\n");
const markupSnippet = String.raw`t.markup('${BASIC_MESSAGES.interpolation}', { name: \`<em>\${markupName}</em>\` })`;
---

<ExampleCard title={helpers.translateText("Basic Translations")}>
  <ExampleSection
    id="basic-static"
    title={helpers.translateText("Static")}
    description={helpers.translateText(
      "Translates a plain string. Falls back to the source text when no translation is loaded for the active locale.",
    )}
    snippet={`t('${BASIC_MESSAGES.static}')`}
  >
    <div class="body text-foreground">{helpers.translateText(BASIC_MESSAGES.static)}</div>
  </ExampleSection>

  <ExampleSection
    id="basic-interpolation"
    title={helpers.translateText("Interpolation")}
    description={helpers.translateText(
      "Replaces {paramToken} placeholders with values at runtime using fast-path string substitution.",
      { paramToken: "{param}" },
    )}
    snippet={`t('${BASIC_MESSAGES.interpolation}', { name: '${state.basicName}' })`}
  >
    <div class="body text-foreground">
      {helpers.translateText(BASIC_MESSAGES.interpolation, { name: state.basicName })}
    </div>
    <Fragment slot="controls">
      <div class="space-y-2">
        <label class={controlLabelClass} for={ASTRO_IDS.basicName}>
          {helpers.translateText("Name")}
        </label>
        <input
          id={ASTRO_IDS.basicName}
          data-bind="basicName"
          type="text"
          value={state.basicName}
          placeholder={helpers.translateText("Name")}
          class={controlInputClass}
        />
      </div>
    </Fragment>
  </ExampleSection>

  <ExampleSection
    id="basic-rich"
    title={helpers.translateText("Rich Text")}
    description={helpers.translateText(
      "{richApi} is currently available via {reactPackage} only. Use {markupApi} for trusted HTML in this framework.",
      {
        richApi: "t.rich()",
        reactPackage: "worldality/react",
        markupApi: "t.markup()",
      },
    )}
    snippet={richTextSnippet}
  >
    <div class="space-y-2">
      <ExampleBadge text={richUnsupported} variant="secondary" />
    </div>
    <ExampleBadge
      slot="title-badge"
      text={helpers.translateText("Not supported")}
      variant="secondary"
    />
  </ExampleSection>

  <ExampleSection
    id="basic-markup"
    title={helpers.translateText("HTML Markup")}
    description={helpers.translateText(
      "Substitutes {paramToken} values into the message and returns a plain string. Values can contain HTML markup and the returned string is intended for {innerHtmlApi}.",
      { paramToken: "{param}", innerHtmlApi: "innerHTML" },
    )}
    snippet={markupSnippet}
  >
    <div
      class="body text-foreground"
      set:html={helpers.translateMarkup(BASIC_MESSAGES.interpolation, {
        name: `<em>${state.markupName}</em>`,
      })}
    />
    <Fragment slot="controls">
      <div class="space-y-2">
        <label class={controlLabelClass} for={ASTRO_IDS.markupName}>
          {helpers.translateText("Name")}
        </label>
        <input
          id={ASTRO_IDS.markupName}
          data-bind="markupName"
          type="text"
          value={state.markupName}
          placeholder={helpers.translateText("Name")}
          class={controlInputClass}
        />
      </div>
    </Fragment>
  </ExampleSection>

  <ExampleSection
    id="basic-meta"
    title={helpers.translateText("Page Metadata")}
    description={helpers.translateText(
      "Translates a string and writes it to the page head. Supports title, description, keywords, {openGraph} tags, and any {cssSelector}.",
      { openGraph: "Open Graph", cssSelector: "CSS selector" },
    )}
    snippet={`t.meta('title', '{siteName} - ${ASTRO_FRAMEWORK.titleSuffix}', { siteName: 'Worldality' })`}
  >
    <code class={codeTextClass}>{pageTitle}</code>
  </ExampleSection>

  <ExampleSection
    id="basic-cache"
    title={helpers.translateText("Cache Check")}
    description={helpers.translateText(
      "Returns {trueToken} if a translation is in the cache for this string in the active locale. Returns {falseToken} in the source locale because the cache is only populated for non-default locales.",
      { trueToken: "true", falseToken: "false" },
    )}
    snippet={`t.has('${BASIC_MESSAGES.static}')`}
  >
    <code class={codeTextClass}>{BASIC_MESSAGES.static}</code>
    <Fragment slot="controls">
      <div class="space-y-2">
        <ExampleBadge text={String(helpers.hasTranslation(BASIC_MESSAGES.static))} />
      </div>
    </Fragment>
  </ExampleSection>

  <ExampleSection
    id="basic-raw"
    title={helpers.translateText("Raw Template")}
    description={helpers.translateText(
      "Returns the raw translated template string with no parameter substitution or formatting applied.",
    )}
    snippet={`t.raw('${BASIC_MESSAGES.interpolation}')`}
  >
    <code class={codeTextClass}>{helpers.rawTemplate(BASIC_MESSAGES.interpolation)}</code>
  </ExampleSection>
</ExampleCard>
