---
import { Minus, Plus } from "@lucide/astro";
import { buttonVariants, cn, inputVariants, labelVariants } from "example-shared/ui";
import {
  DISPLAY_NAMES_DEFAULTS,
  FORMAT_LIST_ITEMS,
} from "example-shared/constants";
import { detectRelativeTimeUnit } from "example-shared/format-handlers";

import type { AstroExampleState } from "../lib/page-state";
import {
  ASTRO_IDS,
  DATE_TIME_PROFILES,
  DISPLAY_NAME_TYPES,
  LIST_TYPES,
  NUMBER_PROFILES,
  RELATIVE_TIME_DELTAS,
} from "../lib/page-state";
import type { AstroServerHelpers } from "../lib/server-helpers";
import ExampleBadge from "./ExampleBadge.astro";
import ExampleCard from "./ExampleCard.astro";
import ExampleSection from "./ExampleSection.astro";

interface Props {
  helpers: AstroServerHelpers;
  state: AstroExampleState;
  today: Date;
  nextWeek: Date;
}

const { helpers, state, today, nextWeek } = Astro.props;
const controlLabelClass = cn(labelVariants());
const controlInputClass = cn(inputVariants(), "body-sm");

function smallButtonClass(
  variant: "outline" | "secondary",
  className = "",
): string {
  return cn(buttonVariants({ variant, size: "sm" }), "body-sm", className);
}

const displayNamesLabel = `${helpers.tDisplayNamesTypeLabel(
  state.displayNamesType,
)} ${helpers.translateText("code")}`;
---

<ExampleCard title={helpers.translateText("Format API Examples")}>
  <ExampleSection
    id="format-number"
    title={helpers.translateText("Number")}
    description={helpers.translateText(
      "Formats a number with {intlNumberFormat} for the active locale. Accepts a named profile ({currencyToken}, {percentToken}, {decimalToken}) or a full options object.",
      {
        intlNumberFormat: "Intl.NumberFormat",
        currencyToken: "currency",
        percentToken: "percent",
        decimalToken: "decimal",
      },
    )}
    snippet={
      state.numberProfile === "currency"
        ? `format.number(${state.numberValue.toFixed(2)}, { style: 'currency', currency: 'USD' })`
        : `format.number(${state.numberValue.toFixed(2)}, '${state.numberProfile}')`
    }
  >
    <div class="body text-foreground">
      {helpers.formatNumberForProfile(state.numberValue, state.numberProfile)}
    </div>
    <Fragment slot="controls">
      <div class="space-y-2">
        <div class="flex flex-wrap gap-2">
          {
            NUMBER_PROFILES.map((value) => (
              <button
                type="button"
                data-action={`number-profile-${value}`}
                class={smallButtonClass(
                  state.numberProfile === value ? "secondary" : "outline",
                )}
              >
                {helpers.tNumberProfileLabel(value)}
              </button>
            ))
          }
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <button
            type="button"
            data-action="number-value-dec"
            class={smallButtonClass("outline")}
            aria-label={helpers.translateText("Decrease value")}
          >
            <Minus class="size-4" aria-hidden="true" />
          </button>
          <button
            type="button"
            data-action="number-value-inc"
            class={smallButtonClass("outline")}
            aria-label={helpers.translateText("Increase value")}
          >
            <Plus class="size-4" aria-hidden="true" />
          </button>
          <span id={ASTRO_IDS.numberValue}>
            <ExampleBadge text={`${helpers.translateText("Value")}: ${state.numberValue.toFixed(2)}`} />
          </span>
        </div>
      </div>
    </Fragment>
  </ExampleSection>

  <ExampleSection
    id="format-datetime"
    title={helpers.translateText("Date & Time")}
    description={helpers.translateText(
      "Formats a Date with {intlDateTimeFormat} for the active locale. Profile names from short through full include both date and time.",
      { intlDateTimeFormat: "Intl.DateTimeFormat" },
    )}
    snippet={`format.dateTime(new Date(), '${state.dateTimeProfile}')`}
  >
    <div class="body text-foreground">
      {helpers.formatDateTime(today, state.dateTimeProfile)}
    </div>
    <Fragment slot="controls">
      <div class="space-y-2">
        <div class="flex flex-wrap gap-2">
          {
            DATE_TIME_PROFILES.map((value) => (
              <button
                type="button"
                data-action={`datetime-profile-${value}`}
                class={smallButtonClass(
                  state.dateTimeProfile === value ? "secondary" : "outline",
                )}
              >
                {helpers.tDateTimeProfileLabel(value)}
              </button>
            ))
          }
        </div>
      </div>
    </Fragment>
  </ExampleSection>

  <ExampleSection
    id="format-daterange"
    title={helpers.translateText("Date Range")}
    description={helpers.translateText(
      "Formats a span between two Date objects with {intlDateTimeFormatRange}. The profile controls the level of detail shown.",
      { intlDateTimeFormatRange: "Intl.DateTimeFormat.formatRange" },
    )}
    snippet={`format.dateTimeRange(today, nextWeek, '${state.dateTimeRangeProfile}')`}
  >
    <div class="body text-foreground">
      {helpers.formatDateTimeRange(today, nextWeek, state.dateTimeRangeProfile)}
    </div>
    <Fragment slot="controls">
      <div class="space-y-2">
        <div class="flex flex-wrap gap-2">
          {
            DATE_TIME_PROFILES.map((value) => (
              <button
                type="button"
                data-action={`daterange-profile-${value}`}
                class={smallButtonClass(
                  state.dateTimeRangeProfile === value ? "secondary" : "outline",
                )}
              >
                {helpers.tDateTimeProfileLabel(value)}
              </button>
            ))
          }
        </div>
      </div>
    </Fragment>
  </ExampleSection>

  <ExampleSection
    id="format-relative"
    title={helpers.translateText("Relative Time")}
    description={helpers.translateText(
      "Converts a duration in seconds to a locale-aware relative string with {intlRelativeTimeFormat}. Automatically selects the most readable unit.",
      { intlRelativeTimeFormat: "Intl.RelativeTimeFormat" },
    )}
    snippet={`format.relativeTime(${state.relativeTimeSeconds})`}
  >
    <div class="body text-foreground">
      {helpers.formatRelativeTime(state.relativeTimeSeconds)}
    </div>
    <Fragment slot="controls">
      <div class="space-y-2">
        <div class="flex flex-wrap gap-2">
          {
            RELATIVE_TIME_DELTAS.map((value) => {
              const abs = Math.abs(value);
              const label =
                abs >= 86400
                  ? `${value > 0 ? "+" : ""}${value / 86400}d`
                  : abs >= 3600
                    ? `${value > 0 ? "+" : ""}${value / 3600}h`
                    : `${value > 0 ? "+" : ""}${value}s`;

              return (
                <button
                  type="button"
                  data-action={`relative-${value}`}
                  class={smallButtonClass("outline")}
                >
                  {label}
                </button>
              );
            })
          }
        </div>
        <div class="flex flex-wrap gap-2">
          <span id={ASTRO_IDS.relativeUnit}>
            <ExampleBadge text={`${helpers.translateText("Unit")}: ${detectRelativeTimeUnit(state.relativeTimeSeconds)}`} />
          </span>
          <span id={ASTRO_IDS.relativeOffset}>
            <ExampleBadge text={`${helpers.translateText("Offset")}: ${state.relativeTimeSeconds}s`} />
          </span>
        </div>
      </div>
    </Fragment>
  </ExampleSection>

  <ExampleSection
    id="format-list"
    title={helpers.translateText("List")}
    description={helpers.translateText(
      "Joins an array of strings into a locale-aware list using {intlListFormat}. Conjunction adds and, disjunction adds or, and unit uses no connector.",
      { intlListFormat: "Intl.ListFormat" },
    )}
    snippet={`format.list([...], { type: '${state.listType}' })`}
  >
    <div class="body text-foreground">
      {helpers.formatList(FORMAT_LIST_ITEMS, state.listType)}
    </div>
    <Fragment slot="controls">
      <div class="space-y-2">
        <div class="flex flex-wrap gap-2">
          {
            LIST_TYPES.map((value) => (
              <button
                type="button"
                data-action={`list-${value}`}
                class={smallButtonClass(
                  state.listType === value ? "secondary" : "outline",
                )}
              >
                {helpers.tListTypeLabel(value)}
              </button>
            ))
          }
        </div>
      </div>
    </Fragment>
  </ExampleSection>

  <ExampleSection
    id="format-displaynames"
    title={helpers.translateText("Display Names")}
    description={helpers.translateText(
      "Translates a {bcp47} or {iso} code into a human-readable name using {intlDisplayNames}. Works for language, region, script, and {currencyToken} codes.",
      {
        bcp47: "BCP 47",
        iso: "ISO",
        intlDisplayNames: "Intl.DisplayNames",
        currencyToken: "currency",
      },
    )}
    snippet={`format.displayNames('${state.displayNamesCode}', { type: '${state.displayNamesType}' })`}
  >
    <div class="body text-foreground">
      {helpers.formatDisplayName(state.displayNamesCode, state.displayNamesType)}
    </div>
    <Fragment slot="controls">
      <div class="space-y-2">
        <div class="space-y-2">
          <label
            id={ASTRO_IDS.displayNamesLabel}
            class={controlLabelClass}
            for={ASTRO_IDS.displayNamesCode}
          >
            {displayNamesLabel}
          </label>
          <input
            id={ASTRO_IDS.displayNamesCode}
            data-bind="displayNamesCode"
            type="text"
            value={state.displayNamesCode}
            placeholder={DISPLAY_NAMES_DEFAULTS[state.displayNamesType]}
            class={controlInputClass}
          />
        </div>
        <div class="flex flex-wrap gap-2">
          {
            DISPLAY_NAME_TYPES.map((value) => (
              <button
                type="button"
                data-action={`display-type-${value}`}
                class={smallButtonClass(
                  state.displayNamesType === value ? "secondary" : "outline",
                )}
              >
                {helpers.tDisplayNamesTypeLabel(value)}
              </button>
            ))
          }
        </div>
      </div>
    </Fragment>
  </ExampleSection>
</ExampleCard>
